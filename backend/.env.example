ENV=development
DEBUG=true

DATABASE_URL=postgresql+asyncpg://anibinge:anibinge@localhost:5432/anibinge
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=replace-with-a-long-random-string
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# MyAnimeList Official API (PRIMARY)
# Register your app at https://myanimelist.net/apiconfig to get these credentials
MAL_CLIENT_ID=
MAL_CLIENT_SECRET=

# Optional: TMDB and YouTube APIs for enhanced media data
TMDB_API_KEY=
YOUTUBE_API_KEY=

RATE_LIMIT_PER_MINUTE=60
CORS_ORIGINS=["http://localhost:3000"]
